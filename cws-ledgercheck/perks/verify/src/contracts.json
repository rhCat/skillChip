{
  "tool": "cws_ledgerverify",
  "inputs": {
    "TARGET_LEDGER": {"type": "string", "required": true},
    "EXPECT_RUN_ID": {"type": "string", "required": false},
    "EXPECT_PLAN_SHA": {"type": "string", "required": false},
    "LEDGER_ALLOW_LEGACY": {"type": "string", "required": false}
  },
  "outputs": {
    "ledgercheck_out": {
      "path": "${RECORD_STORE}/ledgercheck.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/ledgercheck.json"
  }
}

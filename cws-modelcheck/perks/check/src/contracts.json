{
  "tool": "cws_check",
  "inputs": {
    "TARGET_BLUEPRINT": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "modelcheck_out": {
      "path": "${RECORD_STORE}/modelcheck.json",

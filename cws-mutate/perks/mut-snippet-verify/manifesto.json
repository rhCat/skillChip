{
  "_perk": "mut-snippet-verify",
  "sequence": [
    "cws_snippetverify"
  ],
  "tools": {
    "cws_snippetverify": {
      "binary": "python3",
      "params": {
        "PROJECT_DIR": "${PROJECT_DIR}"
      }
    }
  },
  "env": {
    "PROJECT_DIR": "${PROJECT_DIR}",
    "THRESHOLD": "${THRESHOLD}",
    "MAX_MUTANTS": "${MAX_MUTANTS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

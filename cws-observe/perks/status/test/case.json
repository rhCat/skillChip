{
  "_perk": "status",
  "requires": ["python3"],
  "vars": {
    "SWARM_DIR": "${FIXTURE}/swarm"
  },
  "expect": {
    "outputs": ["observe.json"],
    "contains": {
      "observe.json": [
        "\"P0-T01\": \"redeemed\"",
        "\"P0-T02\": \"ready\"",
        "\"P0-T03\": \"blocked:validator\"",
        "\"done_ledger_chain\": \"ok\""
      ]
    }
  }
}

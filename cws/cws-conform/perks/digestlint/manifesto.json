{
  "_perk": "digestlint",
  "sequence": [
    "cws_digestlint"
  ],
  "tools": {
    "cws_digestlint": {
      "binary": "python3",
      "params": {
        "SCAN_ROOT": "${SCAN_ROOT}"
      }
    }
  },
  "env": {
    "SCAN_ROOT": "${SCAN_ROOT}",
    "EXCLUDE": "${EXCLUDE}",
    "WHITELIST": "${WHITELIST}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

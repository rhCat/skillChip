{
  "_perk": "interop",
  "sequence": [
    "cws_interop"
  ],
  "tools": {
    "cws_interop": {
      "binary": "python3",
      "params": {
        "COSIGN_ENVELOPE": "${COSIGN_ENVELOPE}"
      }
    }
  },
  "env": {
    "COSIGN_ENVELOPE": "${COSIGN_ENVELOPE}",
    "COSIGN_PUB": "${COSIGN_PUB}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "openssl",
    "go"
  ]
}

{
  "tool": "fleetmon_status",
  "inputs": {
    "LABEL": {
      "type": "string",
      "required": false
    },
    "PORT": {
      "type": "string",
      "required": false
    },
    "HOST_BIND": {
      "type": "string",
      "required": false
    },
    "MIRROR_DIR": {
      "type": "string",
      "required": false
    },
    "HEARTBEAT_NODE": {
      "type": "string",
      "required": false
    },
    "MIRROR_INTERVAL": {
      "type": "string",
      "required": false
    },
    "FLEET_CONFIG": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "fleetmon_status_out": {
      "path": "${RECORD_STORE}/status.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/status.json"
  }
}

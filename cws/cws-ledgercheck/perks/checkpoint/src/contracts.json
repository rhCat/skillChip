{
  "tool": "cws_checkpoint",
  "inputs": {
    "N": {
      "type": "string",
      "required": false
    },
    "INTERVAL": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "checkpoint_out": {
      "path": "${RECORD_STORE}/checkpoint.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/checkpoint.json"
  }
}
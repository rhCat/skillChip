{
  "_perk": "lotquery",
  "sequence": [
    "cws_lotquery"
  ],
  "tools": {
    "cws_lotquery": {
      "binary": "python3",
      "params": {
        "LEDGER_DB": "${LEDGER_DB}"
      }
    }
  },
  "env": {
    "LEDGER_DB": "${LEDGER_DB}",
    "GROUP_BY": "${GROUP_BY}",
    "LOT": "${LOT}",
    "SINCE": "${SINCE}",
    "LIMIT": "${LIMIT}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

{
  "_perk": "mutate",
  "sequence": [
    "cws_mutate"
  ],
  "tools": {
    "cws_mutate": {
      "binary": "python3",
      "params": {
        "PROJECT_DIR": "${PROJECT_DIR}",
        "TARGET": "${TARGET}",
        "TEST_CMD": "${TEST_CMD}"
      }
    }
  },
  "env": {
    "PROJECT_DIR": "${PROJECT_DIR}",
    "TARGET": "${TARGET}",
    "TEST_CMD": "${TEST_CMD}",
    "THRESHOLD": "${THRESHOLD}",
    "MAX_MUTANTS": "${MAX_MUTANTS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

{
  "_perk": "attest",
  "requires": ["python3"],
  "vars": {
    "CLAIM": "an outsider completed one governed run in under 1h from public docs alone",
    "ATTESTED_BY": "QP",
    "GRADE": "testimony",
    "ATTEST_LEDGER": "${RECORD}/attest-ledger.json"
  },
  "expect": {
    "exit": 0,
    "outputs": ["attest.json", "${RECORD}/attest-ledger.json"],
    "contains": {
      "attest.json": ["\"verdict\": \"recorded\"", "\"attested_by\": \"QP\"", "\"grade\": \"testimony\""],
      "${RECORD}/attest-ledger.json": ["\"chain\": \"attest-ledger\"", "\"type\": \"genesis\"", "\"attested_by\": \"QP\""]
    }
  }
}

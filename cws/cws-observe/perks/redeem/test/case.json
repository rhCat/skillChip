{
  "_perk": "redeem",
  "requires": ["python3"],
  "vars": {
    "SWARM_DIR": "${FIXTURE}/swarm",
    "TASK_ID": "P0-T17",
    "RUN_LEDGER": "${FIXTURE}/evidence/run-ledger.json",
    "DONE_LEDGER": "${RECORD}/done-ledger.json"
  },
  "expect": {
    "outputs": ["redeem.json", "done-ledger-v2.json"],
    "contains": {
      "redeem.json": ["\"verdict\": \"pass\"", "\"task_id\": \"P0-T17\""],
      "done-ledger-v2.json": ["\"task_id\": \"P0-T17\"", "\"verdict\": \"pass\"", "\"type\": \"genesis\""]
    }
  }
}

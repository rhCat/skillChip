{
  "_perk": "coupon",
  "sequence": ["cws_qualify_coupon"],
  "tools": { "cws_qualify_coupon": { "binary": "python3", "params": { "PERFORMER_LOT": "${PERFORMER_LOT}", "COUPONS": "${COUPONS}" } } },
  "env": {
    "PERFORMER_LOT": "${PERFORMER_LOT}", "COUPONS": "${COUPONS}",
    "RUNG": "${RUNG}", "SCOPE": "${SCOPE}",
    "MIN_FIRST_PASS": "${MIN_FIRST_PASS}", "Q_LEDGER": "${Q_LEDGER}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": ["python3"]
}

{
  "tool": "ci_gate",
  "inputs": {
    "PROJECT_DIR": {
      "type": "dir",
      "required": true
    },
    "MODEL_GLOB": {
      "type": "string",
      "required": false
    },
    "SURFACE_GLOB": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "gate_out": {
      "path": "${RECORD_STORE}/gate.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/gate.json"
  }
}

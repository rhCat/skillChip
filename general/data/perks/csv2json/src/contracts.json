{
  "tool": "data_csv2json",
  "inputs": {
    "CSV_FILE": {
      "type": "file",
      "required": true,
      "scan_content": false
    }
  },
  "outputs": {
    "data_csv2json_out": {
      "path": "${RECORD_STORE}/data.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/data.json"
  }
}

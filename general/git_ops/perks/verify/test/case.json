{
  "_perk": "verify",
  "requires": ["git"],
  "setup": [
    "git init -q .",
    "git config user.email t@t",
    "git config user.name t",
    "git config commit.gpgsign false",
    "echo hello > f.txt",
    "git add -A",
    "git commit -q -m init",
    "git remote add origin https://example.invalid/r.git"
  ],
  "vars": { "REPO_DIR": "${FIXTURE}", "REQUIRE": "history+remote" },
  "expect": {
    "exit": 0,
    "outputs": ["git_verify.json"],
    "json": { "git_verify.json": { "satisfied": true, "status": "ok" } }
  }
}

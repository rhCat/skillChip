{
  "_perk": "test",
  "sequence": [
    "py_test"
  ],
  "tools": {
    "py_test": {
      "binary": "python3",
      "params": {
        "PROJECT_DIR": "${PROJECT_DIR}",
        "TEST_DIR": "${TEST_DIR}",
        "PYTEST_ARGS": "${PYTEST_ARGS}"
      }
    }
  },
  "env": {
    "PROJECT_DIR": "${PROJECT_DIR}",
    "TEST_DIR": "${TEST_DIR}",
    "PYTEST_ARGS": "${PYTEST_ARGS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

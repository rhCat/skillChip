{
  "tool": "sec_secrets",
  "inputs": {
    "SEARCH_DIR": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "sec_secrets_out": {
      "path": "${RECORD_STORE}/secrets_report.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/secrets_report.json"
  }
}

{
  "tool": "ssh_run",
  "inputs": {
    "SSH_HOST": {
      "type": "string",
      "required": true
    },
    "SSH_USER": {
      "type": "string",
      "required": true
    },
    "COMMAND": {
      "type": "string",
      "required": true
    },
    "SSH_KEY_FILE": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "ssh_output_log": {
      "path": "${RECORD_STORE}/ssh_output.log",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/ssh_output.log"
  }
}

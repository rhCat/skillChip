    "DEV_EVAL": "python eval.py --split dev --n 50",
    "TEST_EVAL": "python eval.py --split test --n 300",
    "MATERIAL": ".",
    "METRIC_DIRECTION": "max",
    "BRANCHING": "3",
    "MAX_DEPTH": "2",

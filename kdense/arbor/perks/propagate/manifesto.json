{
  "_perk": "propagate",
  "sequence": [
    "arbor_propagate"
  ],
  "tools": {
    "arbor_propagate": {
      "binary": "python3",
      "params": {
        "NODE": "${NODE}",
        "INSIGHT": "${INSIGHT}",
        "TO_ROOT": "${TO_ROOT}"
      }
    }
  },
  "env": {
    "NODE": "${NODE}",
    "INSIGHT": "${INSIGHT}",
    "TO_ROOT": "${TO_ROOT}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

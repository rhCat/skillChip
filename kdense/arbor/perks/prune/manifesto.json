{
  "_perk": "prune",
  "sequence": [
    "arbor_prune"
  ],
  "tools": {
    "arbor_prune": {
      "binary": "python3",
      "params": {
        "NODE": "${NODE}",
        "REASON": "${REASON}"
      }
    }
  },
  "env": {
    "NODE": "${NODE}",
    "REASON": "${REASON}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

    "NODE": "${NODE}",
    "DEV_SCORE": "${DEV_SCORE}",
    "RESULT": "${RESULT}",
    "INSIGHT": "${INSIGHT}",
    "BRANCH_REF": "${BRANCH_REF}",
    "RECORD_STORE": "${record_store}"

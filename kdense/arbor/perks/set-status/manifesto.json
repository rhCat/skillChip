{
  "_perk": "set-status",
  "sequence": [
    "arbor_set_status"
  ],
  "tools": {
    "arbor_set_status": {
      "binary": "python3",
      "params": {
        "NODE": "${NODE}",
        "STATUS": "${STATUS}"
      }
    }
  },
  "env": {
    "NODE": "${NODE}",
    "STATUS": "${STATUS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

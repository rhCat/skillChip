{
  "_perk": "grnboost2",
  "sequence": [
    "grnboost2"
  ],
  "tools": {
    "grnboost2": {
      "binary": "python3",
      "params": {
        "EXPRESSION_FILE": "${EXPRESSION_FILE}",
        "TF_FILE": "${TF_FILE}",
        "SEED": "${SEED}",
        "LIMIT": "${LIMIT}"
      }
    }
  },
  "env": {
    "EXPRESSION_FILE": "${EXPRESSION_FILE}",
    "TF_FILE": "${TF_FILE}",
    "SEED": "${SEED}",
    "LIMIT": "${LIMIT}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "bash",
    "python3"
  ]
}

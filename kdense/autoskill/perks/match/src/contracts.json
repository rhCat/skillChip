{
  "tool": "match_skills",
  "inputs": {
    "CLUSTERS": {
      "type": "string",
      "required": true
    },
    "SKILLS_DIR": {
      "type": "string",
      "required": true
    },
    "TOP_K": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "matches": {
      "path": "${RECORD_STORE}/matches.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/matches.json"
  }
}

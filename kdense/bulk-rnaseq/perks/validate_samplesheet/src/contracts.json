{
  "tool": "validate_samplesheet",
  "inputs": {
    "SAMPLESHEET": {
      "type": "string",
      "required": true
    },
    "METADATA": {
      "type": "string",
      "required": false
    },
    "CONDITION_COL": {
      "type": "string",
      "required": false
    },
    "MIN_REPLICATES": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "validation_report": {
      "path": "${RECORD_STORE}/validation_report.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/validation_report.txt"
  }
}

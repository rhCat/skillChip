{
  "tool": "search_scholar",
  "inputs": {
    "QUERY": {
      "type": "string",
      "required": true
    },
    "LIMIT": {
      "type": "string",
      "required": false
    },
    "SORT_BY": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "search_scholar_out": {
      "path": "${RECORD_STORE}/scholar.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/scholar.json"
  }
}

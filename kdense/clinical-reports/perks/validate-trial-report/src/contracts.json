{
  "tool": "validate_trial_report",
  "inputs": {
    "REPORT_FILE": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "ich_e3_validation": {
      "path": "${RECORD_STORE}/ich_e3_validation.json",

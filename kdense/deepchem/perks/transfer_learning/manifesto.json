{
  "_perk": "transfer_learning",
  "sequence": [
    "transfer_learning"
  ],
  "tools": {
    "transfer_learning": {
      "binary": "python3",
      "params": {
        "MODEL": "${MODEL}",
        "DATASET": "${DATASET}",
        "DATA_CSV": "${DATA_CSV}",
        "TARGET": "${TARGET}",
        "SMILES_COL": "${SMILES_COL}",
        "TASK_TYPE": "${TASK_TYPE}",
        "EPOCHS": "${EPOCHS}"
      }
    }
  },
  "env": {
    "MODEL": "${MODEL}",
    "DATASET": "${DATASET}",
    "DATA_CSV": "${DATA_CSV}",
    "TARGET": "${TARGET}",
    "SMILES_COL": "${SMILES_COL}",
    "TASK_TYPE": "${TASK_TYPE}",
    "EPOCHS": "${EPOCHS}",
    "RECORD_STORE": "${record_store}"
  },

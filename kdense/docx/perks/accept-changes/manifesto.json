{
  "_perk": "accept-changes",
  "sequence": [
    "docx_accept_changes"
  ],
  "tools": {
    "docx_accept_changes": {
      "binary": "bash",
      "params": {
        "DOCX_FILE": "${DOCX_FILE}"
      }
    }
  },
  "env": {
    "DOCX_FILE": "${DOCX_FILE}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "bash",
    "python3"
  ]
}

{
  "tool": "ete_convert",
  "inputs": {
    "TREE_FILE": {
      "type": "string",
      "required": true
    },
    "IN_FORMAT": {
      "type": "string",
      "required": false
    },
    "OUT_FORMAT": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "ete_convert_out": {
      "path": "${RECORD_STORE}/convert.log",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/convert.log"
  }
}

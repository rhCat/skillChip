{
  "_perk": "generate",
  "sequence": [
    "generate_image"
  ],
  "tools": {
    "generate_image": {
      "binary": "python3",
      "params": {
        "PROMPT": "${PROMPT}",
        "MODEL": "${MODEL}",
        "OUTPUT_NAME": "${OUTPUT_NAME}"
      }
    }
  },
  "env": {
    "PROMPT": "${PROMPT}",
    "MODEL": "${MODEL}",
    "OUTPUT_NAME": "${OUTPUT_NAME}",
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

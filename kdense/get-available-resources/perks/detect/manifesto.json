{
  "_perk": "detect",
  "sequence": [
    "detect_resources"
  ],
  "tools": {
    "detect_resources": {
      "binary": "python3",
      "params": {
        "PROBE_PATH": "${PROBE_PATH}"
      }
    }
  },
  "env": {
    "PROBE_PATH": "${PROBE_PATH}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

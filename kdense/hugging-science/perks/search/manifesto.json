{
  "_perk": "search",
  "sequence": [
    "hs_search"
  ],
  "tools": {
    "hs_search": {
      "binary": "python3",
      "params": {
        "QUERY": "${QUERY}",
        "FILTER": "${FILTER}",
        "TAG": "${TAG}",
        "FORMAT": "${FORMAT}"
      }
    }
  },
  "env": {
    "QUERY": "${QUERY}",
    "FILTER": "${FILTER}",
    "TAG": "${TAG}",
    "FORMAT": "${FORMAT}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

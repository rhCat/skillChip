{
  "_perk": "generate",
  "sequence": [
    "generate_infographic"
  ],
  "tools": {
    "generate_infographic": {
      "binary": "python3",
      "params": {
        "PROMPT": "${PROMPT}",
        "OUTPUT_NAME": "${OUTPUT_NAME}",
        "INFOGRAPHIC_TYPE": "${INFOGRAPHIC_TYPE}",
        "STYLE": "${STYLE}",
        "PALETTE": "${PALETTE}",
        "DOC_TYPE": "${DOC_TYPE}",
        "ITERATIONS": "${ITERATIONS}",
        "RESEARCH": "${RESEARCH}"
      }
    }
  },
  "env": {
    "PROMPT": "${PROMPT}",
    "OUTPUT_NAME": "${OUTPUT_NAME}",
    "INFOGRAPHIC_TYPE": "${INFOGRAPHIC_TYPE}",
    "STYLE": "${STYLE}",
    "PALETTE": "${PALETTE}",
    "DOC_TYPE": "${DOC_TYPE}",
    "ITERATIONS": "${ITERATIONS}",
    "RESEARCH": "${RESEARCH}",
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

{
  "_perk": "batch_convert",
  "sequence": [
    "batch_convert"
  ],
  "tools": {
    "batch_convert": {
      "binary": "python3",
      "params": {
        "INPUT_DIR": "${INPUT_DIR}"
      }
    }
  },
  "env": {
    "INPUT_DIR": "${INPUT_DIR}",
    "EXTENSIONS": "${EXTENSIONS}",
    "RECURSIVE": "${RECURSIVE}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

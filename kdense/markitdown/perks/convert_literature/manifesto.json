{
  "_perk": "convert_literature",
  "sequence": [
    "convert_literature"
  ],
  "tools": {
    "convert_literature": {
      "binary": "python3",
      "params": {
        "INPUT_DIR": "${INPUT_DIR}"
      }
    }
  },
  "env": {
    "INPUT_DIR": "${INPUT_DIR}",
    "ORGANIZE_BY_YEAR": "${ORGANIZE_BY_YEAR}",
    "CREATE_INDEX": "${CREATE_INDEX}",
    "RECURSIVE": "${RECURSIVE}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

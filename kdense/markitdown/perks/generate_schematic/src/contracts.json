{
  "tool": "generate_schematic",
  "inputs": {
    "PROMPT": {
      "type": "string",
      "required": true
    },
    "DOC_TYPE": {
      "type": "string",
      "required": false
    },
    "ITERATIONS": {
      "type": "string",
      "required": false
    },
    "OPENROUTER_API_KEY": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "generate_schematic_out": {
      "path": "${RECORD_STORE}/generate_schematic_summary.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/generate_schematic_summary.json"
  }
}

{
  "tool": "mc_alerts",
  "inputs": {
    "INPUT": {
      "type": "string",
      "required": true
    },
    "ALERTS": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "mc_alerts_out": {
      "path": "${RECORD_STORE}/alerts.csv",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/alerts.csv"
  }
}

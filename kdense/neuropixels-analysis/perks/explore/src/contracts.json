{
  "tool": "explore_recording",
  "inputs": {
    "DATA_PATH": {
      "type": "string",
      "required": true
    },
    "STREAM_NAME": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "explore_report": {
      "path": "${RECORD_STORE}/explore_report.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/explore_report.txt"
  }
}

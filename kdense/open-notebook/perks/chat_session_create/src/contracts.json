{
  "tool": "chat_session_create",
  "inputs": {
    "OPEN_NOTEBOOK_URL": {
      "type": "string",
      "required": true
    },
    "NOTEBOOK_ID": {
      "type": "string",
      "required": true
    },
    "SESSION_TITLE": {
      "type": "string",
      "required": false
    },
    "MODEL_OVERRIDE": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "chat_session_out": {
      "path": "${RECORD_STORE}/chat_session.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/chat_session.json"
  }
}

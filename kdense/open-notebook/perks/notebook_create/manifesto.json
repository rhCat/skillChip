{
  "_perk": "notebook_create",
  "sequence": [
    "notebook_create"
  ],
  "tools": {
    "notebook_create": {
      "binary": "bash",
      "params": {
        "OPEN_NOTEBOOK_URL": "${OPEN_NOTEBOOK_URL}",
        "NB_NAME": "${NB_NAME}",
        "NB_DESCRIPTION": "${NB_DESCRIPTION}"
      }
    }
  },
  "env": {
    "OPEN_NOTEBOOK_URL": "${OPEN_NOTEBOOK_URL}",
    "NB_NAME": "${NB_NAME}",
    "NB_DESCRIPTION": "${NB_DESCRIPTION}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

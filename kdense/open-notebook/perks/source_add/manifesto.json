{
  "_perk": "source_add",
  "sequence": [
    "source_add"
  ],
  "tools": {
    "source_add": {
      "binary": "bash",
      "params": {
        "OPEN_NOTEBOOK_URL": "${OPEN_NOTEBOOK_URL}",
        "NOTEBOOK_ID": "${NOTEBOOK_ID}",
        "SOURCE_URL": "${SOURCE_URL}",
        "SOURCE_TEXT": "${SOURCE_TEXT}",
        "SOURCE_TITLE": "${SOURCE_TITLE}"
      }
    }
  },
  "env": {
    "OPEN_NOTEBOOK_URL": "${OPEN_NOTEBOOK_URL}",
    "NOTEBOOK_ID": "${NOTEBOOK_ID}",
    "SOURCE_URL": "${SOURCE_URL}",
    "SOURCE_TEXT": "${SOURCE_TEXT}",
    "SOURCE_TITLE": "${SOURCE_TITLE}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

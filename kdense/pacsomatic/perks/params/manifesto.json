{
  "_perk": "params",
  "sequence": [
    "build_params"
  ],
  "tools": {
    "build_params": {
      "binary": "bash",
      "params": {
        "OUTDIR": "${OUTDIR}",
        "SAMPLESHEET": "${SAMPLESHEET}",
        "FASTA": "${FASTA}",
        "GENOME": "${GENOME}"
      }
    }
  },
  "env": {
    "OUTDIR": "${OUTDIR}",
    "SAMPLESHEET": "${SAMPLESHEET}",
    "FASTA": "${FASTA}",
    "GENOME": "${GENOME}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "bash",
    "python3"
  ]
}

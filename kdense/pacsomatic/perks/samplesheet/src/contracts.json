{
  "tool": "build_samplesheet",
  "inputs": {
    "PATIENT_ID": {
      "type": "string",
      "required": true
    },
    "TUMOR_SAMPLE_ID": {
      "type": "string",
      "required": true
    },
    "NORMAL_SAMPLE_ID": {
      "type": "string",
      "required": true
    },
    "TUMOR_BAM": {
      "type": "string",
      "required": true
    },
    "NORMAL_BAM": {
      "type": "string",
      "required": true
    },
    "TUMOR_PBI": {
      "type": "string",
      "required": false
    },
    "NORMAL_PBI": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "out": {
      "path": "${RECORD_STORE}/samplesheet.csv",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/samplesheet.csv"
  }
}

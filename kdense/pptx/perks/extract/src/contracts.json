{
  "tool": "extract",
  "inputs": {
    "PPTX_FILE": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "extract_out": {
      "path": "${RECORD_STORE}/extract.md",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/extract.md"
  }
}

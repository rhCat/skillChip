{
  "_perk": "pack",
  "sequence": [
    "pack"
  ],
  "tools": {
    "pack": {
      "binary": "python3",
      "params": {
        "UNPACKED_DIR": "${UNPACKED_DIR}"
      }
    }
  },
  "env": {
    "UNPACKED_DIR": "${UNPACKED_DIR}",
    "ORIGINAL_PPTX": "${ORIGINAL_PPTX}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

{
  "tool": "thumbnail",
  "inputs": {
    "PPTX_FILE": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "thumbnail_out": {
      "path": "${RECORD_STORE}/thumbnail.log",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/thumbnail.log"
  }
}

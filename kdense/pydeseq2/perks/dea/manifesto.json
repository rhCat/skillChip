{
  "_perk": "dea",
  "sequence": [
    "run_dea"
  ],
  "tools": {
    "run_dea": {
      "binary": "python3",
      "params": {
        "COUNTS": "${COUNTS}",
        "METADATA": "${METADATA}",
        "DESIGN": "${DESIGN}",
        "CONTRAST": "${CONTRAST}"
      }
    }
  },
  "env": {
    "COUNTS": "${COUNTS}",
    "METADATA": "${METADATA}",
    "DESIGN": "${DESIGN}",
    "CONTRAST": "${CONTRAST}",
    "MIN_COUNTS": "${MIN_COUNTS}",
    "ALPHA": "${ALPHA}",
    "N_CPUS": "${N_CPUS}",
    "SHRINK_COEFF": "${SHRINK_COEFF}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

{
  "_perk": "filter",
  "sequence": [
    "filter_counts"
  ],
  "tools": {
    "filter_counts": {
      "binary": "python3",
      "params": {
        "COUNTS": "${COUNTS}",
        "METADATA": "${METADATA}",
        "MIN_COUNTS": "${MIN_COUNTS}",
        "CONDITION_COL": "${CONDITION_COL}"
      }
    }
  },
  "env": {
    "COUNTS": "${COUNTS}",
    "METADATA": "${METADATA}",
    "MIN_COUNTS": "${MIN_COUNTS}",
    "CONDITION_COL": "${CONDITION_COL}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

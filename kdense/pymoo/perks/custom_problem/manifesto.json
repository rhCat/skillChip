{
  "_perk": "custom_problem",
  "sequence": [
    "pymoo_custom_problem"
  ],
  "tools": {
    "pymoo_custom_problem": {
      "binary": "python3",
      "params": {
        "POP_SIZE": "${POP_SIZE}",
        "N_GEN": "${N_GEN}"
      }
    }
  },
  "env": {
    "POP_SIZE": "${POP_SIZE}",
    "N_GEN": "${N_GEN}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

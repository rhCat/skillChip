{
  "_perk": "single_objective",
  "sequence": [
    "pymoo_single_objective"
  ],
  "tools": {
    "pymoo_single_objective": {
      "binary": "python3",
      "params": {
        "PROBLEM": "${PROBLEM}",
        "N_VAR": "${N_VAR}",
        "POP_SIZE": "${POP_SIZE}",
        "N_GEN": "${N_GEN}"
      }
    }
  },
  "env": {
    "PROBLEM": "${PROBLEM}",
    "N_VAR": "${N_VAR}",
    "POP_SIZE": "${POP_SIZE}",
    "N_GEN": "${N_GEN}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

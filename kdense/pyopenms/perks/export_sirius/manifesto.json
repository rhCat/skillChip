{
  "_perk": "export_sirius",
  "sequence": [
    "export_sirius"
  ],
  "tools": {
    "export_sirius": {
      "binary": "bash",
      "params": {
        "INPUT": "${INPUT}"
      }
    }
  },
  "env": {
    "INPUT": "${INPUT}",
    "FEATUREXML": "${FEATUREXML}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

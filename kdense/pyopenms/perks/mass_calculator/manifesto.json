{
  "_perk": "mass_calculator",
  "sequence": [
    "mass_calculator"
  ],
  "tools": {
    "mass_calculator": {
      "binary": "bash",
      "params": {
        "PEPTIDE": "${PEPTIDE}",
        "FORMULA": "${FORMULA}"
      }
    }
  },
  "env": {
    "PEPTIDE": "${PEPTIDE}",
    "FORMULA": "${FORMULA}",
    "CHARGES": "${CHARGES}",
    "ISOTOPES": "${ISOTOPES}",
    "NEGATIVE": "${NEGATIVE}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

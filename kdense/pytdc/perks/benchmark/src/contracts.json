{
  "tool": "tdc_benchmark",
  "inputs": {
    "TDC_GROUP": {
      "type": "string",
      "required": true
    },
    "TDC_PRED": {
      "type": "string",
      "required": true
    },
    "TDC_PATH": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "bench_out": {
      "path": "${RECORD_STORE}/bench.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/bench.json"
  }
}

{
  "tool": "tdc_evaluate",
  "inputs": {
    "TDC_METRIC": {
      "type": "string",
      "required": true
    },
    "TDC_PRED": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "eval_out": {
      "path": "${RECORD_STORE}/eval.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/eval.json"
  }
}

{
  "tool": "scaffold_module",
  "inputs": {
    "OUT_NAME": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "scaffold_module_out": {
      "path": "${RECORD_STORE}/${OUT_NAME}",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/${OUT_NAME}"
  }
}

{
  "_perk": "score_genes",
  "sequence": [
    "score_genes"
  ],
  "tools": {
    "score_genes": {
      "binary": "python3",
      "params": {
        "INPUT": "${INPUT}"
      }
    }
  },
  "env": {
    "INPUT": "${INPUT}",
    "GENE_SETS": "${GENE_SETS}",
    "CELL_CYCLE": "${CELL_CYCLE}",
    "NO_PLOTS": "${NO_PLOTS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

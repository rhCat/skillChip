{
  "tool": "fill_fillable",
  "inputs": {
    "PDF_PATH": {
      "type": "string",
      "required": true
    },
    "FIELDS_JSON": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "fill_fillable_out": {
      "path": "${RECORD_STORE}/fill_fillable.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/fill_fillable.txt"
  }
}

{
  "_perk": "preprocess",
  "sequence": [
    "preprocess"
  ],
  "tools": {
    "preprocess": {
      "binary": "python3",
      "params": {
        "INPUT": "${INPUT}"
      }
    }
  },
  "env": {
    "INPUT": "${INPUT}",
    "MIN_SHARED_COUNTS": "${MIN_SHARED_COUNTS}",
    "N_TOP_GENES": "${N_TOP_GENES}",
    "N_NEIGHBORS": "${N_NEIGHBORS}",
    "N_PCS": "${N_PCS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

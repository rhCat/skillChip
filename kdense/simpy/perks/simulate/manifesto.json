{
  "_perk": "simulate",
  "sequence": [
    "simpy_simulate"
  ],
  "tools": {
    "simpy_simulate": {
      "binary": "python3",
      "params": {
        "SIM_TIME": "${SIM_TIME}",
        "NUM_RESOURCES": "${NUM_RESOURCES}",
        "ARRIVAL_RATE": "${ARRIVAL_RATE}",
        "SERVICE_TIME_MEAN": "${SERVICE_TIME_MEAN}",
        "RANDOM_SEED": "${RANDOM_SEED}"
      }
    }
  },
  "env": {
    "SIM_TIME": "${SIM_TIME}",
    "NUM_RESOURCES": "${NUM_RESOURCES}",
    "ARRIVAL_RATE": "${ARRIVAL_RATE}",
    "SERVICE_TIME_MEAN": "${SERVICE_TIME_MEAN}",
    "RANDOM_SEED": "${RANDOM_SEED}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

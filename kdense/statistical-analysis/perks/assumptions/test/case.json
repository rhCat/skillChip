{
  "_perk": "assumptions",
  "requires": ["python3"],
  "vars": {
    "DATA_CSV": "${FIXTURE}/data.csv",
    "VALUE_COL": "score",
    "GROUP_COL": "group",
    "ALPHA": "0.05"
  },
  "expect": {
    "exit": 0,
    "outputs": ["assumptions.json"],
    "nonempty": ["assumptions.json"],
    "json": {
      "assumptions.json": { "summary": { "all_assumptions_met": true } }
    }
  }
}

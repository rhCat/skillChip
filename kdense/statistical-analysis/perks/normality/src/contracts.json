{
  "tool": "check_normality",
  "inputs": {
    "DATA_CSV": {
      "type": "string",
      "required": true
    },
    "VALUE_COL": {
      "type": "string",
      "required": true
    },
    "ALPHA": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "normality_report": {
      "path": "${RECORD_STORE}/normality.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/normality.json"
  }
}

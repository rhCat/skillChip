{
  "tool": "detect_outliers",
  "inputs": {
    "DATA_CSV": {
      "type": "string",
      "required": true
    },
    "VALUE_COL": {
      "type": "string",
      "required": true
    },
    "METHOD": {
      "type": "string",
      "required": false
    },
    "THRESHOLD": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "outliers_report": {
      "path": "${RECORD_STORE}/outliers.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/outliers.json"
  }
}

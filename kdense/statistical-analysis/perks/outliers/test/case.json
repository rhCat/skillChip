{
  "_perk": "outliers",
  "requires": ["python3"],
  "vars": {
    "DATA_CSV": "${FIXTURE}/data.csv",
    "VALUE_COL": "score",
    "METHOD": "iqr",
    "THRESHOLD": "1.5"
  },
  "expect": {
    "exit": 0,
    "outputs": ["outliers.json", "outliers.png"],
    "nonempty": ["outliers.json"],
    "json": {
      "outliers.json": { "method": "iqr", "n_outliers": 0 }
    }
  }
}

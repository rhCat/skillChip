{
  "tool": "power_mde",
  "inputs": {
    "TEST": {
      "type": "string",
      "required": true
    },
    "NOBS1": {
      "type": "number",
      "required": false
    },
    "ALPHA": {
      "type": "number",
      "required": false
    },
    "POWER": {
      "type": "number",
      "required": false
    }
  },
  "outputs": {
    "mde_out": {
      "path": "${RECORD_STORE}/mde.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/mde.json"
  }
}

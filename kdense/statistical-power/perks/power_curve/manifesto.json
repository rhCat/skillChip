{
  "_perk": "power_curve",
  "sequence": [
    "power_curve"
  ],
  "tools": {
    "power_curve": {
      "binary": "bash",
      "params": {
        "TEST": "${TEST}",
        "EFFECT_SIZE": "${EFFECT_SIZE}",
        "ALPHA": "${ALPHA}",
        "POWER": "${POWER}"
      }
    }
  },
  "env": {
    "TEST": "${TEST}",
    "EFFECT_SIZE": "${EFFECT_SIZE}",
    "ALPHA": "${ALPHA}",
    "POWER": "${POWER}",
    "ALTERNATIVE": "${ALTERNATIVE}",
    "N_START": "${N_START}",
    "N_STOP": "${N_STOP}",
    "N_STEP": "${N_STEP}",
    "RATIO": "${RATIO}",
    "K_GROUPS": "${K_GROUPS}",
    "PROP1": "${PROP1}",
    "PROP2": "${PROP2}",
    "PROP0": "${PROP0}",
    "DOF": "${DOF}",
    "DF_NUM": "${DF_NUM}",
    "K_TOTAL": "${K_TOTAL}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "bash"
  ]
}

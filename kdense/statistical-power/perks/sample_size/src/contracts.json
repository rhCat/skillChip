{
  "tool": "power_sample_size",
  "inputs": {
    "TEST": {
      "type": "string",
      "required": true
    },
    "EFFECT_SIZE": {
      "type": "number",
      "required": false
    },
    "ALPHA": {
      "type": "number",
      "required": false
    },
    "POWER": {
      "type": "number",
      "required": false
    }
  },
  "outputs": {
    "sample_size_out": {
      "path": "${RECORD_STORE}/sample_size.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/sample_size.json"
  }
}

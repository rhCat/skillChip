{
  "tool": "simulate_power",
  "inputs": {
    "DESIGN": {
      "type": "string",
      "required": true
    },
    "N": {
      "type": "number",
      "required": false
    },
    "N_SIMS": {
      "type": "number",
      "required": false
    },
    "EFFECT": {
      "type": "number",
      "required": false
    }
  },
  "outputs": {
    "simulate_power_out": {
      "path": "${RECORD_STORE}/simulate_power.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/simulate_power.json"
  }
}

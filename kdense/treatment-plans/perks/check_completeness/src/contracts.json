{
  "tool": "check_completeness",
  "inputs": {
    "PLAN_FILE": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "completeness_report": {
      "path": "${RECORD_STORE}/completeness.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/completeness.txt"
  }
}

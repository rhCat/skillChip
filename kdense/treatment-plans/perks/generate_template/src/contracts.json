{
  "tool": "generate_template",
  "inputs": {
    "TEMPLATE_TYPE": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "template": {
      "path": "${RECORD_STORE}/template.tex",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/template.tex"
  }
}

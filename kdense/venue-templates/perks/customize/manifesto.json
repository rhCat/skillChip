{
  "_perk": "customize",
  "sequence": [
    "customize_template"
  ],
  "tools": {
    "customize_template": {
      "binary": "python3",
      "params": {
        "TEMPLATE": "${TEMPLATE}",
        "TITLE": "${TITLE}",
        "AUTHORS": "${AUTHORS}",
        "AFFILIATIONS": "${AFFILIATIONS}",
        "EMAIL": "${EMAIL}"
      }
    }
  },
  "env": {
    "TEMPLATE": "${TEMPLATE}",
    "TITLE": "${TITLE}",
    "AUTHORS": "${AUTHORS}",
    "AFFILIATIONS": "${AFFILIATIONS}",
    "EMAIL": "${EMAIL}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

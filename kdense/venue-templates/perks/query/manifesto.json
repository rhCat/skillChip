{
  "_perk": "query",
  "sequence": [
    "query_template"
  ],
  "tools": {
    "query_template": {
      "binary": "python3",
      "params": {
        "VENUE": "${VENUE}",
        "TEMPLATE_TYPE": "${TEMPLATE_TYPE}",
        "KEYWORD": "${KEYWORD}"
      }
    }
  },
  "env": {
    "VENUE": "${VENUE}",
    "TEMPLATE_TYPE": "${TEMPLATE_TYPE}",
    "KEYWORD": "${KEYWORD}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

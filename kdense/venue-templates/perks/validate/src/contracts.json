{
  "tool": "validate_format",
  "inputs": {
    "PDF_FILE": {
      "type": "string",
      "required": true
    },
    "VENUE": {
      "type": "string",
      "required": true
    },
    "CHECKS": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "validation_report": {
      "path": "${RECORD_STORE}/validation_report.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/validation_report.txt"
  }
}

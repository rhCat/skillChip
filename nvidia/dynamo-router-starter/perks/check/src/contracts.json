{
  "tool": "check_router_health",
  "inputs": {
    "BASE_URL": {
      "type": "string",
      "required": true
    },
    "RETRIES": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "router_health": {
      "path": "${RECORD_STORE}/router_health.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/router_health.json"
  }
}

{
  "_perk": "troubleshoot",
  "sequence": [
    "collect_dynamo_debug_bundle"
  ],
  "tools": {
    "collect_dynamo_debug_bundle": {
      "binary": "python3",
      "params": {
        "NAMESPACE": "${NAMESPACE}",
        "DEPLOYMENT_NAME": "${DEPLOYMENT_NAME}"
      }
    }
  },
  "env": {
    "NAMESPACE": "${NAMESPACE}",
    "DEPLOYMENT_NAME": "${DEPLOYMENT_NAME}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3",
    "kubectl"
  ]
}

{
  "tool": "make_manifest",
  "inputs": {
    "VERSION": {
      "type": "string",
      "required": true
    },
    "MANIFEST": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "flash_manifest": {
      "path": "${RECORD_STORE}/manifest.yaml",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/manifest.yaml"
  }
}

{
  "_perk": "generate",
  "sequence": [
    "run_mr_brain"
  ],
  "tools": {
    "run_mr_brain": {
      "binary": "python3",
      "params": {
        "MODEL_CONFIG": "${MODEL_CONFIG}",
        "OUTPUT_DIR": "${OUTPUT_DIR}",
        "MODALITY": "${MODALITY}"
      }
    }
  },
  "env": {
    "MODEL_CONFIG": "${MODEL_CONFIG}",
    "OUTPUT_DIR": "${OUTPUT_DIR}",
    "MODALITY": "${MODALITY}",
    "NV_GENERATE_ROOT": "${NV_GENERATE_ROOT}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

{
  "_perk": "generate",
  "sequence": [
    "render_defect_spec"
  ],
  "tools": {
    "render_defect_spec": {
      "binary": "python3",
      "params": {
        "DEFECT_PAIRS": "${DEFECT_PAIRS}",
        "SPATIAL_DEPENDENCY": "${SPATIAL_DEPENDENCY}"
      }
    }
  },
  "env": {
    "DEFECT_PAIRS": "${DEFECT_PAIRS}",
    "SPATIAL_DEPENDENCY": "${SPATIAL_DEPENDENCY}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

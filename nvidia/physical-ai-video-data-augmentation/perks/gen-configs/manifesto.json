{
  "_perk": "gen-configs",
  "sequence": [
    "generate_configs"
  ],
  "tools": {
    "generate_configs": {
      "binary": "bash",
      "params": {
        "INPUT_DIR": "${INPUT_DIR}",
        "CONFIG_DIR": "${CONFIG_DIR}"
      }
    }
  },
  "env": {
    "INPUT_DIR": "${INPUT_DIR}",
    "CONFIG_DIR": "${CONFIG_DIR}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "bash",
    "python3"
  ]
}

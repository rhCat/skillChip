{
  "_perk": "discover-streams",
  "requires": [
    "bash",
    "python3"
  ],
  "vars": {
    "USECASE": "warehouse-2d",
    "STREAM_COUNT": "4",
    "RESOURCES": "${FIXTURE}"
  },

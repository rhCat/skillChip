{
  "_perk": "generate-batch",
  "requires": ["python3"],
  "vars": {
    "INPUT": "${FIXTURE}",
    "MODEL": "gpt-image-1.5",
    "SIZE": "1024x1024",
    "QUALITY": "auto",
    "CONCURRENCY": "2"

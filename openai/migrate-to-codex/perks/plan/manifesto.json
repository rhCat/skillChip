{
  "_perk": "plan",
  "sequence": [
    "mtc_plan"
  ],
  "tools": {
    "mtc_plan": {
      "binary": "python3",
      "params": {
        "SOURCE": "${SOURCE}",
        "TARGET": "${TARGET}"
      }
    }
  },
  "env": {
    "SOURCE": "${SOURCE}",
    "TARGET": "${TARGET}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

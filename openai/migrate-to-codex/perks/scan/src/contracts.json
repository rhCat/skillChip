{
  "tool": "mtc_scan",
  "inputs": {
    "SOURCE": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "mtc_scan_out": {
      "path": "${RECORD_STORE}/scan.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/scan.txt"
  }
}

{
  "tool": "mtc_validate",
  "inputs": {
    "TARGET": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "mtc_validate_out": {
      "path": "${RECORD_STORE}/validate.txt",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/validate.txt"
  }
}

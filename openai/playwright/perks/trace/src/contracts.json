{
  "tool": "pw_trace",
  "inputs": {
    "PW_SESSION": {
      "type": "string",
      "required": false
    }
  },
  "outputs": {
    "pw_trace_out": {
      "path": "${RECORD_STORE}/trace.json",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/trace.json"
  }
}

{
  "_perk": "community_maintainers",
  "sequence": [
    "community_maintainers"
  ],
  "tools": {
    "community_maintainers": {
      "binary": "python3",
      "params": {
        "DATA_DIR": "${DATA_DIR}",
        "CM_ARGS": "${CM_ARGS}"
      }
    }
  },
  "env": {
    "DATA_DIR": "${DATA_DIR}",
    "CM_ARGS": "${CM_ARGS}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

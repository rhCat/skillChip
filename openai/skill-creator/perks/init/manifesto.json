{
  "_perk": "init",
  "sequence": [
    "init_skill"
  ],
  "tools": {
    "init_skill": {
      "binary": "python3",
      "params": {
        "SKILL_NAME": "${SKILL_NAME}",
        "OUTPUT_PATH": "${OUTPUT_PATH}",
        "RESOURCES": "${RESOURCES}"
      }
    }
  },
  "env": {
    "SKILL_NAME": "${SKILL_NAME}",
    "OUTPUT_PATH": "${OUTPUT_PATH}",
    "RESOURCES": "${RESOURCES}",
    "RECORD_STORE": "${record_store}"
  },
  "requires": [
    "python3"
  ]
}

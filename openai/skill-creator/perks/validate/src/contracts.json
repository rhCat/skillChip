{
  "tool": "validate_skill",
  "inputs": {
    "SKILL_DIR": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "validate_out": {
      "path": "${RECORD_STORE}/validate.out",
      "type": "file"
    }
  },
  "checks": {
    "exit_zero": true,
    "output_exists": "${RECORD_STORE}/validate.out"
  }
}
